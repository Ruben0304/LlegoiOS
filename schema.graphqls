schema {
  query: Query
  mutation: Mutation
  subscription: Subscription
}
"Date with time (isoformat)"
scalar DateTime
"The `JSON` scalar type represents JSON values as specified by [ECMA-404](https://ecma-international.org/wp-content/uploads/ECMA-404_2nd_edition_december_2017.pdf)."
scalar JSON
scalar Upload
type Query {
  "Lista de usuarios (requiere rol admin o manager)"
  users(jwt: String!): [UserType!]!
  "Obtener usuario por ID (requiere rol admin o manager)"
  user(id: String!, jwt: String!): UserType
  "Buscar usuarios (requiere autenticación)"
  searchUsers(query: String!, jwt: String!): [UserType!]!
  "Usuario actual desde JWT"
  me(jwt: String!): UserType
  "Lista de negocios (query pública/admin)"
  businesses(ownerId: String = null, jwt: String = null): [BusinessType!]!
  "Obtener negocio por ID"
  business(id: String!, jwt: String = null): BusinessType
  "Buscar negocios"
  searchBusinesses(query: String!, limit: Int! = 10, useVectorSearch: Boolean! = true, jwt: String = null): [BusinessType!]!
  "Obtener todos mis negocios con sucursales (propios + compartidos)"
  getMyBusinessesWithBranches(jwt: String!): [BusinessWithBranchesType!]!
  "Lista de sucursales con scoring por cercanía (paginado)"
  branches(first: Int = null, after: String = null, businessId: String = null, tipo: BranchTipo = null, radiusKm: Float = null, productCategoryId: String = null, jwt: String = null): BranchConnection!
  "Obtener sucursal por ID"
  branch(id: String!, jwt: String = null): BranchType
  "Buscar sucursales con scoring por cercanía (paginado)"
  searchBranches(query: String!, first: Int = null, after: String = null, useVectorSearch: Boolean! = true, productCategoryId: String = null, radiusKm: Float = null, jwt: String = null): BranchConnection!
  "Buscar sucursales cercanas por coordenadas (paginado)"
  nearbyBranches(longitude: Float!, latitude: Float!, first: Int = null, after: String = null, radiusKm: Float! = 5, onlyActive: Boolean! = true, tipo: BranchTipo = null, productCategoryId: String = null, jwt: String = null): NearbyBranchConnection!
  "Obtener ubicación de una sucursal desde MongoDB"
  branchLocation(branchId: String!, jwt: String = null): CoordinatesType
  "Obtener todas las sucursales a las que tengo acceso (propias + compartidas)"
  getMyBranches(jwt: String!): [BranchType!]!
  "Lista de productos con scoring por cercanía (paginado)"
  products(first: Int = null, after: String = null, ids: [String!] = null, branchId: String = null, categoryId: String = null, availableOnly: Boolean! = false, branchTipo: BranchTipo = null, radiusKm: Float = null, jwt: String = null): ProductConnection!
  "Obtener producto por ID"
  product(id: String!, jwt: String = null): ProductType
  "Buscar productos con scoring por cercanía (paginado)"
  searchProducts(query: String!, first: Int = null, after: String = null, useVectorSearch: Boolean! = true, branchTipo: BranchTipo = null, categoryId: String = null, radiusKm: Float = null, jwt: String = null): ProductConnection!
  "Obtener recomendaciones de productos complementarios basadas en items del carrito"
  productRecommendations(productIds: [String!]!, limit: Int! = 5, jwt: String = null): ProductRecommendationsResponseType
  "Obtener productos de la misma branch/sucursal, excluyendo el producto dado"
  productsFromSameBranch(productId: String!, limit: Int! = 10, jwt: String = null): [ProductType!]!
  "Obtener vitrina por ID"
  showcase(showcaseId: String!, jwt: String = null): ShowcaseType
  "Obtener vitrinas por sucursal"
  showcasesByBranch(branchId: String!, activeOnly: Boolean! = true, jwt: String = null): [ShowcaseType!]!
  "Obtener todas las vitrinas"
  allShowcases(activeOnly: Boolean! = false, jwt: String = null): [ShowcaseType!]!
  "Lista de categorías con subcategorías"
  categories(jwt: String = null): [CategoryType!]!
  "Obtener categoría por ID"
  category(id: String!, jwt: String = null): CategoryType
  "Get all product categories"
  productCategories(branchType: String = null): [ProductCategoryType!]!
  "Get product category by ID"
  productCategory(id: String!): ProductCategoryType
  "Obtener un combo por ID"
  combo(comboId: String!): ComboType
  "Obtener todos los combos de una sucursal"
  combosByBranch(branchId: String!, availableOnly: Boolean! = true): [ComboType!]!
  "Obtener todos los combos"
  allCombos(availableOnly: Boolean! = false): [ComboType!]!
  "Semantic vector search across products, branches, or businesses. Returns enriched results from Qdrant + MongoDB."
  semanticSearch(query: String!, collection: SemanticSearchCollection!, limit: Int! = 10, jwt: String = null): SemanticSearchResultType!
  "Send a message to the AI assistant and get a response with RAG"
  aiChat(input: AiAssistantChatInput!, jwt: String = null): AiAssistantResponseType
  "Obtener mis pedidos con paginación"
  myOrders(jwt: String!, status: OrderStatusEnum = null, limit: Int! = 20, offset: Int! = 0): OrdersConnectionType!
  "Obtener un pedido por ID"
  order(id: String!, jwt: String!): OrderType
  "Obtener pedido por número de orden"
  orderByNumber(orderNumber: String!, jwt: String!): OrderType
  "Tracking completo de un pedido"
  orderTracking(orderId: String!, jwt: String!): OrderTrackingType
  "Pedidos de una sucursal"
  branchOrders(branchId: String!, jwt: String!, status: OrderStatusEnum = null, fromDate: DateTime = null, toDate: DateTime = null, limit: Int! = 50, offset: Int! = 0): OrdersConnectionType!
  "Pedidos pendientes de una sucursal"
  pendingBranchOrders(branchId: String!, jwt: String!): [OrderType!]!
  "Pedidos disponibles para repartidores cerca"
  availableOrdersForDelivery(latitude: Float!, longitude: Float!, jwt: String!, radiusKm: Float! = 5): [OrderType!]!
  "Pedido actual del repartidor"
  myCurrentDelivery(jwt: String!): OrderType
  "Historial de pedidos del repartidor autenticado"
  myDeliveries(jwt: String!, status: OrderStatusEnum = null, page: Int! = 1, pageSize: Int! = 20): [OrderType!]!
  "Estadísticas del repartidor autenticado"
  myDeliveryStats(jwt: String!): DeliveryPersonStatsType!
  "Mis solicitudes de vinculación a sucursales"
  myBranchLinkRequests(jwt: String!, status: DeliveryRequestStatusEnum = null): [BranchDeliveryRequestType!]!
  "Solicitudes de vinculación a una sucursal (para managers)"
  branchLinkRequests(branchId: String!, jwt: String!, status: DeliveryRequestStatusEnum = null): [BranchDeliveryRequestType!]!
  "Estadísticas de pedidos"
  orderStats(fromDate: DateTime!, toDate: DateTime!, jwt: String!, branchId: String = null): OrderStatsType!
  "Estimar precio de envío antes de crear el pedido. Usa la ubicación guardada del usuario autenticado."
  estimateDeliveryFee(branchId: String!, jwt: String!, subtotal: Float! = 0): DeliveryFeeEstimateType!
  "Estadísticas del dashboard: ingresos, pedidos completados/rechazados y productos más vendidos por período (today, week, month)"
  dashboardStats(businessId: String!, period: DashboardPeriod!, jwt: String!): DashboardStatsType!
  "Get business type configurations (supports incremental sync)"
  businessTypeConfigs(lastSyncAt: DateTime = null): [BusinessTypeConfigType!]!
  "Obtener todos los métodos de pago disponibles. Si se provee branchId, retorna solo los aceptados por ese branch."
  paymentMethods(branchId: String = null, jwt: String = null): [PaymentMethodType!]!
  "Obtener método de pago por ID"
  paymentMethod(id: String!, jwt: String = null): PaymentMethodType
  "Obtener métodos de pago por moneda"
  paymentMethodsByCurrency(currency: String!, jwt: String = null): [PaymentMethodType!]!
  "Obtener métodos de pago por tipo"
  paymentMethodsByMethod(method: String!, jwt: String = null): [PaymentMethodType!]!
  "Obtener intento de pago por ID"
  paymentAttempt(id: String!, jwt: String!): PaymentAttemptType
  "Obtener intentos de pago de un pedido"
  paymentAttemptsByOrder(orderId: String!, jwt: String!): [PaymentAttemptType!]!
  "Obtener el intento de pago activo de un pedido"
  activePaymentAttempt(orderId: String!, jwt: String!): PaymentAttemptType
  "Obtener balance de wallet del usuario actual"
  myWallet(jwt: String!): WalletStatusType!
  "Obtener historial de transacciones del usuario actual"
  myWalletTransactions(jwt: String!, limit: Int! = 50, skip: Int! = 0, currency: String = null): [WalletTransactionType!]!
  "Obtener balance de wallet de una sucursal"
  branchWallet(branchId: String!, jwt: String!): WalletStatusType!
  "Obtener historial de transacciones de una sucursal"
  branchWalletTransactions(branchId: String!, jwt: String!, limit: Int! = 50, skip: Int! = 0, currency: String = null): [WalletTransactionType!]!
  "Vista previa de una invitacion por codigo"
  invitationByCode(code: String!, jwt: String = null): BranchInvitationType
  "Todas las invitaciones de un negocio (dueno)"
  invitationsByBusiness(businessId: String!, jwt: String!): [BranchInvitationType!]!
  "Invitaciones activas de un negocio (dueno)"
  activeInvitationsByBusiness(businessId: String!, jwt: String!): [BranchInvitationType!]!
  "Accesos a negocio por negocio (dueno)"
  businessAccessByBusiness(businessId: String!, jwt: String!): [BusinessAccessType!]!
  "Mis accesos a negocios"
  myBusinessAccess(jwt: String!): [BusinessAccessType!]!
  "Obtener configuración de la aplicación de clientes"
  appConfig: AppConfigType
  "Obtener configuración de la aplicación de negocios"
  businessAppConfig: BusinessAppConfigType
  "Obtener todos los feedbacks (requiere rol admin)"
  feedbacks(jwt: String!): [FeedbackType!]!
  "Obtener feedback por ID"
  feedback(id: String!, jwt: String!): FeedbackType
  "Obtener mis feedbacks"
  myFeedbacks(jwt: String!): [FeedbackType!]!
  "Obtener feedbacks por tipo (requiere rol admin)"
  feedbacksByType(type: FeedbackTypeEnum!, jwt: String!): [FeedbackType!]!
  "Obtener feedbacks por estado (requiere rol admin)"
  feedbacksByStatus(status: FeedbackStatusEnum!, jwt: String!): [FeedbackType!]!
  "Obtener todas las encuestas activas"
  activeSurveys(jwt: String!): [SurveyType!]!
  "Obtener todas las encuestas (requiere rol admin)"
  allSurveys(jwt: String!): [SurveyType!]!
  "Obtener encuesta por ID"
  survey(id: String!, jwt: String!): SurveyType
  "Obtener respuestas por encuesta (requiere rol admin)"
  surveyResponses(surveyId: String!, jwt: String!): [SurveyResponseType!]!
  "Obtener mis respuestas a encuestas"
  mySurveyResponses(jwt: String!): [SurveyResponseType!]!
  "Verificar si el usuario ya respondió una encuesta"
  hasRespondedToSurvey(surveyId: String!, jwt: String!): Boolean!
  "Get personalized feed with multiple sections"
  getFeed(branchTipo: String!, first: Int! = 10, radiusKm: Float = null, sections: [String!] = null, productCategoryId: String = null, jwt: String = null): FeedResponse!
  "Get all tutorials"
  tutorials: [TutorialType!]!
  "Get active tutorials only"
  activeTutorials: [TutorialType!]!
  "Get tutorials by app target"
  tutorialsByApp(appTarget: AppTarget!): [TutorialType!]!
  "Get tutorial by ID"
  tutorial(id: String!): TutorialType
  "Search tutorials by title, description or tags"
  searchTutorials(query: String!): [TutorialType!]!
  "Get tutorials by tags"
  tutorialsByTags(tags: [String!]!): [TutorialType!]!
  "Buscar transferencias pendientes por transfer_id y/o teléfono"
  findPendingTransfers(jwt: String!, transferId: String = null, phone: String = null): [ShortcutTransferType!]!
  "Obtener listas de variantes por negocio"
  variantLists(businessId: String!, jwt: String = null): [VariantListType!]!
  "Obtener lista de variantes por ID"
  variantList(id: String!, jwt: String = null): VariantListType
  "Sincronizar negocios con sus branches (excluye datos sensibles como managerIds y ownerId)"
  syncBusinessesWithBranches(jwt: String = null): [BusinessSyncType!]!
  "Sincronizar productos (todos los productos disponibles)"
  syncProducts(branchId: String = null, categoryId: String = null, availableOnly: Boolean! = false, jwt: String = null): [ProductSyncType!]!
  "Sincronizar imágenes con URLs para diferentes calidades (baja 100x100, original)"
  syncImages(entityType: String = null, entityIds: [String!] = null, qualities: [ImageQuality!] = null, jwt: String = null): [ImageSyncType!]!
  "Saludo de ejemplo"
  hello(jwt: String = null): String!
  "Saluda por nombre"
  greet(name: String! = "mundo", jwt: String = null): String!
}
type UserType {
  id: String!
  name: String!
  email: String!
  username: String!
  phone: String
  role: String!
  avatar: String
  businessIds: [String!]!
  branchIds: [String!]!
  businessAccessIds: [String!]!
  createdAt: DateTime!
  authProvider: String!
  providerUserId: String
  applePrivateEmail: String
  wallet: WalletBalanceType!
  walletStatus: String!
  isPro: Boolean!
  location: JSON
  aiConsultasLimit: JSON
  savedAddresses: [SavedAddressType!]!
  defaultAddressId: String
  "URL firmada del avatar del usuario"
  avatarUrl: String
}
type WalletBalanceType {
  local: Float!
  usd: Float!
}
type SavedAddressType {
  id: String!
  label: String!
  street: String!
  city: String
  reference: String
  addressType: String!
  buildingName: String
  floor: String
  apartment: String
  deliveryInstructions: String
  latitude: Float!
  longitude: Float!
}
type BusinessType {
  id: String!
  name: String!
  ownerId: String!
  globalRating: Float!
  avatar: String
  description: String
  tags: [String!]
  isActive: Boolean!
  createdAt: DateTime!
  "Presigned URL for the business avatar"
  avatarUrl: String
}
type BusinessWithBranchesType {
  id: String!
  name: String!
  ownerId: String!
  globalRating: Float!
  avatar: String
  description: String
  tags: [String!]
  isActive: Boolean!
  createdAt: DateTime!
  branches: [BranchType!]!
  isOwner: Boolean!
  role: String!
  "Presigned URL for the business avatar"
  avatarUrl: String
}
type BranchType {
  id: String!
  businessId: String!
  name: String!
  address: String
  coordinates: CoordinatesType!
  phone: String!
  schedule: JSON!
  managerIds: [String!]!
  isActive: Boolean!
  status: String
  avatar: String
  coverImage: String
  socialMedia: JSON
  tipos: [BranchTipo!]!
  paymentMethodIds: [String!]!
  useAppMessaging: Boolean!
  vehicles: [BranchVehicle!]!
  accounts: [TransferAccountType!]!
  qrPayments: [QrPaymentType!]!
  phones: [TransferPhoneType!]!
  deliveryRadius: Float
  createdAt: DateTime!
  wallet: WalletBalanceType!
  walletStatus: String!
  "Presigned URL for the branch avatar (inherits from business if not set)"
  avatarUrl: String
  "Presigned URL for the branch cover image"
  coverUrl: String
  "Products from this branch"
  products(limit: Int! = 6, availableOnly: Boolean! = true): [ProductType!]!
  "Payment methods accepted by this branch"
  paymentMethods: [PaymentMethodType!]!
}
type CoordinatesType {
  type: String!
  coordinates: [Float!]!
}
type TransferAccountType {
  cardNumber: String!
  cardHolderName: String!
  bankName: String!
  isActive: Boolean!
}
type QrPaymentType {
  value: String!
  isActive: Boolean!
}
type TransferPhoneType {
  phone: String!
  isActive: Boolean!
}
type ProductType {
  id: String!
  branchId: String!
  name: String!
  description: String!
  weight: String!
  price: Float!
  currency: String!
  image: String!
  availability: Boolean!
  categoryId: String
  variantListIds: [String!]!
  createdAt: DateTime!
  "Presigned URL for the product image"
  imageUrl: String!
  "Product category name"
  categoryName: String
  "Variant lists assigned to this product"
  variantLists: [VariantListType!]!
  "Product category"
  category: ProductCategoryType
  "Branch associated with this product"
  branch: BranchType
  "Business associated with this product (through branch)"
  business: BusinessType
}
type VariantListType {
  id: String!
  businessId: String!
  name: String!
  description: String
  options: [VariantOptionType!]!
  createdAt: DateTime!
  updatedAt: DateTime!
  "Business associated with this variant list"
  business: BusinessType
}
type VariantOptionType {
  id: String!
  name: String!
  priceAdjustment: Float!
}
type ProductCategoryType {
  id: String!
  branchType: String!
  name: String!
  iconIos: String!
  iconWeb: String!
  iconAndroid: String!
  createdAt: DateTime!
}
type PaymentMethodType {
  "Payment method ID"
  id: String!
  "Display name"
  name: String!
  "Internal code"
  code: String!
  "Currency code"
  currency: String!
  "Method type"
  method: String!
  "Commission percentage charged"
  commissionPercent: Float!
  "Delivery fee percentage"
  deliveryFeePercent: Float!
  "Whether refunds are allowed"
  isRefundable: Boolean!
  "Whether proof is required"
  requiresProof: Boolean!
  "Whether business confirmation is required"
  requiresBusinessConfirmation: Boolean!
  "Expiration in minutes"
  expirationMinutes: Int
  "Whether method is active"
  isActive: Boolean!
  "Display order"
  displayOrder: Int!
  "Icon URL"
  iconUrl: String
  "Payment instructions"
  instructions: String
  "Creation time"
  createdAt: DateTime!
  "Last update time"
  updatedAt: DateTime!
}
type BranchConnection {
  edges: [BranchEdge!]!
  pageInfo: PageInfo!
}
type BranchEdge {
  node: ScoredBranchType!
  cursor: String!
}
