}
type ShowcaseType {
  id: String!
  branchId: String!
  title: String!
  image: String!
  description: String
  items: [ShowcaseItemType!]
  isActive: Boolean!
  createdAt: DateTime!
  updatedAt: DateTime!
  "Presigned URL for the showcase image"
  imageUrl: String!
  "Branch associated with this showcase"
  branch: BranchType
}
