  status: String
  avatar: String
  coverImage: String
  socialMedia: JSON
  tipos: [BranchTipo!]!
  paymentMethodIds: [String!]!
  useAppMessaging: Boolean!
  vehicles: [BranchVehicle!]!
  accounts: [TransferAccountType!]!
  qrPayments: [QrPaymentType!]!
  phones: [TransferPhoneType!]!
  deliveryRadius: Float
  createdAt: DateTime!
  score: Float!
  distanceM: Float
  wallet: WalletBalanceType!
  walletStatus: String!
  "Presigned URL for the branch avatar (inherits from business if not set)"
  avatarUrl: String
  "Presigned URL for the branch cover image"
  coverUrl: String
  "Distance in kilometers from user"
  distanceKm: Float
  "Products from this branch"
  products(limit: Int! = 6, availableOnly: Boolean! = true): [ProductType!]!
  "Payment methods accepted by this branch"
  paymentMethods: [PaymentMethodType!]!
}
type PageInfo {
  hasNextPage: Boolean!
  hasPreviousPage: Boolean!
  startCursor: String
  endCursor: String
  totalCount: Int!
}
type NearbyBranchConnection {
  edges: [NearbyBranchEdge!]!
