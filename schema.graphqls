  id: String!
  name: String!
  description: String
  price: Float
  availability: Boolean!
}
type CategoryType {
  id: String!
  name: String!
  imageUrl: String!
  subcategories: [SubcategoryType!]!
  createdAt: DateTime!
}
type SubcategoryType {
  name: String!
  imageUrl: String!
}
type ComboType {
  id: String!
  branchId: String!
  name: String!
  description: String!
  image: String
  slots: [ComboSlotType!]!
  discountType: DiscountType!
  discountValue: Float!
  currency: String!
  availability: Boolean!
  categoryId: String
  createdAt: DateTime!
  updatedAt: DateTime!
  "Presigned URL for combo image (optional)"
  imageUrl: String
  "Representative products for frontend composition (one per slot)"
  representativeProducts: [ProductType!]!
  "Base price with default selections (before discount)"
  basePrice: Float!
  "Final price with discount applied"
  finalPrice: Float!
  "Amount saved with discount"
  savings: Float!
  "Branch associated with this combo"
  branch: BranchType
}
type ComboSlotType {
  id: String!
  name: String!
  description: String
  options: [ComboOptionType!]!
  minSelections: Int!
  maxSelections: Int!
  isRequired: Boolean!
  displayOrder: Int!
}
type ComboOptionType {
  productId: String!
  isDefault: Boolean!
  priceAdjustment: Float!
  availableModifiers: [ComboModifierType!]!
  "Product details"
  product: ProductType
}
type ComboModifierType {
  name: String!
  priceAdjustment: Float!
}
type SemanticSearchResultType {
  "Collection that was searched: products, branches, or businesses"
  collection: String!
  "Total number of results returned"
  totalResults: Int!
  "Product results (populated when collection=products)"
  products: [SemanticSearchProductResult!]!
  "Branch results (populated when collection=branches)"
  branches: [SemanticSearchBranchResult!]!
  "Business results (populated when collection=businesses)"
  businesses: [SemanticSearchBusinessResult!]!
}
type SemanticSearchProductResult {
  "Similarity score from vector search (0.0 to 1.0)"
  score: Float!
  "The matched product"
  product: ProductType!
  "Branch name where product is sold"
  branchName: String
  "Branch avatar S3 key"
  branchAvatar: String
  "Branch address"
  branchAddress: String
  "Branch phone number"
  branchPhone: String
  "Presigned URL for the branch avatar"
  branchAvatarUrl: String
}
type SemanticSearchBranchResult {
  "Similarity score from vector search (0.0 to 1.0)"
  score: Float!
