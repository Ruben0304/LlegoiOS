  distanceM: Float!
  wallet: WalletBalanceType!
  walletStatus: String!
  "Presigned URL for the branch avatar (inherits from business if not set)"
  avatarUrl: String
  "Presigned URL for the branch cover image"
  coverUrl: String
  "Distance in kilometers"
  distanceKm: Float!
  "Products from this branch"
  products(limit: Int! = 6, availableOnly: Boolean! = true): [ProductType!]!
  "Payment methods accepted by this branch"
