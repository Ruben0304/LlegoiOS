type Mutation {
  "Register a new user"
  register(input: RegisterInput!, jwt: String = null): AuthResponse!
  "Login with email and password"
  login(input: LoginInput!, jwt: String = null): AuthResponse!
  "Login with Google"
  loginWithGoogle(input: SocialLoginInput!, jwt: String = null): AuthResponse!
  "Login with Apple"
  loginWithApple(input: AppleLoginInput!, jwt: String = null): AuthResponse!
  "Actualizar perfil de usuario"
  updateUser(input: UpdateUserInput!, jwt: String = null): UserType!
  "Agregar sucursal a usuario"
  addBranchToUser(input: AddBranchToUserInput!, jwt: String = null): UserType!
  "Remover sucursal de usuario"
  removeBranchFromUser(branchId: String!, jwt: String = null): UserType!
  "Eliminar cuenta de usuario"
  deleteUser(jwt: String = null): Boolean!
  "Actualizar ubicación del usuario"
  updateLocation(input: UpdateLocationInput!, jwt: String = null): UserType!
  "Guardar una nueva dirección de entrega en el perfil"
  addSavedAddress(input: SavedAddressInput!, jwt: String = null): UserType!
  "Editar una dirección guardada en el perfil"
  updateSavedAddress(input: UpdateSavedAddressInput!, jwt: String = null): UserType!
  "Eliminar una dirección guardada del perfil"
  removeSavedAddress(addressId: String!, jwt: String = null): UserType!
  "Establecer la dirección de entrega por defecto"
  setDefaultAddress(addressId: String!, jwt: String = null): UserType!
  "Registrar un nuevo negocio con al menos una sucursal"
  registerBusiness(businessInput: CreateBusinessInput!, branchesInput: [RegisterBranchInput!]!, jwt: String = null): BusinessType!
  "Actualizar un negocio"
  updateBusiness(businessId: String!, input: UpdateBusinessInput!, jwt: String = null): BusinessType!
  "Registrar múltiples negocios con sus sucursales en una sola operación"
  registerMultipleBusinesses(businessesInput: [RegisterBusinessWithBranchesInput!]!, jwt: String = null): [BusinessType!]!
  "Eliminar un negocio y todas sus sucursales"
  deleteBusiness(businessId: String!, jwt: String = null): Boolean!
  "Crear una nueva sucursal"
  createBranch(input: CreateBranchInput!, jwt: String = null): BranchType!
  "Actualizar una sucursal"
  updateBranch(branchId: String!, input: UpdateBranchInput!, jwt: String = null): BranchType!
  "Eliminar una sucursal"
  deleteBranch(branchId: String!, jwt: String = null): Boolean!
  "Crear un nuevo producto"
  createProduct(input: CreateProductInput!, jwt: String = null): ProductType!
  "Actualizar un producto"
  updateProduct(productId: String!, input: UpdateProductInput!, jwt: String = null): ProductType!
  "Eliminar un producto"
  deleteProduct(productId: String!, jwt: String = null): Boolean!
  "Crear una vitrina"
  createShowcase(input: CreateShowcaseInput!, jwt: String = null): ShowcaseType!
  "Actualizar una vitrina"
  updateShowcase(showcaseId: String!, input: UpdateShowcaseInput!, jwt: String = null): ShowcaseType!
  "Eliminar una vitrina"
  deleteShowcase(showcaseId: String!, jwt: String = null): Boolean!
  "Cambiar disponibilidad de una vitrina"
  toggleShowcaseAvailability(showcaseId: String!, isActive: Boolean!, jwt: String = null): ShowcaseType!
  "Crear un nuevo combo"
  createCombo(input: CreateComboInput!, jwt: String = null): ComboType!
  "Actualizar un combo existente"
  updateCombo(input: UpdateComboInput!, jwt: String = null): ComboType!
  "Eliminar un combo"
  deleteCombo(comboId: String!, jwt: String = null): Boolean!
  "Cambiar disponibilidad de un combo"
  toggleComboAvailability(comboId: String!, availability: Boolean!, jwt: String = null): ComboType!
  "Crear nuevo pedido"
  createOrder(input: CreateOrderInput!, jwt: String!): OrderType!
  "Aceptar modificaciones de la tienda"
  acceptOrderModifications(orderId: String!, jwt: String!): OrderType!
  "Rechazar modificaciones y cancelar pedido"
  rejectOrderModifications(orderId: String!, jwt: String!): OrderType!
  "Cancelar pedido"
  cancelOrder(orderId: String!, jwt: String!, reason: String = null): OrderType!
  "Añadir comentario al pedido"
  addOrderComment(input: AddOrderCommentInput!, jwt: String!): OrderType!
  "Calificar pedido después de entrega"
  rateOrder(orderId: String!, rating: Int!, jwt: String!, comment: String = null): OrderType!
  "Aceptar pedido. Si se proporciona deliveryFee, el branch establece manualmente el precio de envío."
  acceptOrder(orderId: String!, estimatedMinutes: Int!, jwt: String!, deliveryFee: Float = null): OrderType!
  "Rechazar pedido"
  rejectOrder(orderId: String!, reason: String!, jwt: String!): OrderType!
  "Modificar items del pedido"
  modifyOrderItems(input: ModifyOrderItemsInput!, jwt: String!): OrderType!
  "Actualizar estado del pedido"
  updateOrderStatus(input: UpdateOrderStatusInput!, jwt: String!): OrderType!
  "Marcar pedido como listo para recoger"
  markOrderReady(orderId: String!, jwt: String!): OrderType!
  "Aceptar pedido para entrega"
  acceptDelivery(orderId: String!, jwt: String!): OrderType!
  "Confirmar recogida del pedido"
  confirmPickup(orderId: String!, jwt: String!): OrderType!
  "Actualizar ubicación durante la entrega"
  updateDeliveryLocation(input: UpdateDeliveryLocationInput!, jwt: String!): Boolean!
  "Confirmar entrega completada"
  confirmDelivery(orderId: String!, jwt: String!): OrderType!
  "Asignar repartidor manualmente"
  assignDeliveryPerson(input: AssignDeliveryPersonInput!, jwt: String!): OrderType!
  "Solicitar vinculación a una sucursal como repartidor"
  requestBranchLink(input: RequestBranchLinkInput!, jwt: String!): BranchDeliveryRequestType!
  "Responder a una solicitud de vinculación (manager)"
  respondBranchLinkRequest(input: RespondBranchLinkInput!, jwt: String!): BranchDeliveryRequestType!
  "Cancelar solicitud de vinculación propia"
  cancelBranchLinkRequest(requestId: String!, jwt: String!): Boolean!
  "Forzar cambio de estado (admin)"
  forceOrderStatus(orderId: String!, status: OrderStatusEnum!, reason: String!, jwt: String!): OrderType!
  "Register device token for push notifications"
  registerDeviceToken(input: RegisterDeviceTokenInput!, jwt: String = null): DeviceTokenType!
  "Unregister device token"
  unregisterDeviceToken(token: String!): Boolean!
  "Create new business type configuration (Admin only, triggers push notification)"
  createBusinessTypeConfig(input: CreateBusinessTypeConfigInput!, jwt: String!): BusinessTypeConfigType!
  "Update business type configuration (Admin only, triggers push notification)"
  updateBusinessTypeConfig(id: String!, input: UpdateBusinessTypeConfigInput!, jwt: String!): BusinessTypeConfigType!
  "Deactivate business type configuration (Admin only)"
  deactivateBusinessTypeConfig(id: String!, jwt: String!): BusinessTypeConfigType!
  "Delete business type configuration permanently (Admin only)"
  deleteBusinessTypeConfig(id: String!, jwt: String!): Boolean!
  "Validar una imagen de transferencia bancaria usando Gemini OCR"
  validatePaymentImage(file: Upload!, jwt: String = null): PaymentType!
  "Iniciar un pago para un pedido"
  initiatePayment(orderId: String!, paymentMethodId: String!, jwt: String!, includeDeliveryFee: Boolean! = true, sendsSmsNotification: Boolean! = false): InitiatePaymentResult!
  "Confirmar que el cliente envió el pago (para métodos manuales)"
  confirmPaymentSent(paymentAttemptId: String!, proofUrl: String!, jwt: String!): PaymentAttemptType!
  "Negocio confirma que recibió el pago"
  confirmPaymentReceived(paymentAttemptId: String!, jwt: String!): PaymentAttemptType!
  "Repartidor confirma que recibió el pago en efectivo"
  confirmCashReceived(paymentAttemptId: String!, jwt: String!): PaymentAttemptType!
  "Negocio disputa que no recibió el pago"
  disputePayment(paymentAttemptId: String!, reason: String!, jwt: String!): PaymentAttemptType!
  "Solicitar reembolso de un pago"
  requestRefund(paymentAttemptId: String!, reason: String!, jwt: String!): PaymentAttemptType!
  "Confirmar automáticamente un pago por transferencia usando el sistema de Shortcut Transfers. Busca por el teléfono del perfil del usuario; si no hay coincidencia, el cliente puede proveer el ID de transferencia."
  confirmTransferByShortcut(paymentAttemptId: String!, jwt: String!, transferId: String = null): PaymentAttemptType!
  "Cancelar un intento de pago pendiente"
  cancelPayment(paymentAttemptId: String!, jwt: String!): PaymentAttemptType!
  "Transferir dinero a otro usuario o sucursal"
  transferMoney(input: TransferInput!, jwt: String!): WalletTransactionType!
  "Depositar dinero en la wallet"
  depositMoney(input: DepositInput!, jwt: String!): WalletTransactionType!
  "Retirar dinero de la wallet"
  withdrawMoney(input: WithdrawInput!, jwt: String!): WalletTransactionType!
  "Transferir dinero desde wallet de sucursal"
  branchTransferMoney(branchId: String!, input: TransferInput!, jwt: String!): WalletTransactionType!
  "Retirar dinero de wallet de sucursal"
  branchWithdrawMoney(branchId: String!, input: WithdrawInput!, jwt: String!): WalletTransactionType!
  "Generar codigo de invitacion"
  generateInvitationCode(input: GenerateInvitationInput!, jwt: String = null): BranchInvitationType!
  "Canjear codigo de invitacion"
  acceptInvitationCode(input: AcceptInvitationInput!, jwt: String = null): BranchInvitationType!
  "Revocar codigo de invitacion"
  revokeInvitationCode(invitationId: String!, jwt: String = null): Boolean!
  "Actualizar configuración de la aplicación (requiere rol admin)"
  updateAppConfig(input: UpdateAppConfigInput!, jwt: String!): AppConfigType
  "Actualizar configuración de la aplicación de negocios (requiere rol admin)"
  updateBusinessAppConfig(input: UpdateAppConfigInput!, jwt: String!): BusinessAppConfigType
  "Crear un nuevo feedback"
  createFeedback(input: CreateFeedbackInput!, jwt: String!): FeedbackType!
  "Actualizar estado de feedback (requiere rol admin)"
  updateFeedbackStatus(feedbackId: String!, input: UpdateFeedbackStatusInput!, jwt: String!): FeedbackType!
  "Eliminar un feedback"
  deleteFeedback(feedbackId: String!, jwt: String!): Boolean!
  "Crear una nueva encuesta (requiere rol admin)"
  createSurvey(input: CreateSurveyInput!, jwt: String!): SurveyType!
  "Actualizar una encuesta (requiere rol admin)"
  updateSurvey(surveyId: String!, input: UpdateSurveyInput!, jwt: String!): SurveyType!
  "Desactivar una encuesta (requiere rol admin)"
  deactivateSurvey(surveyId: String!, jwt: String!): SurveyType!
  "Enviar respuesta a una encuesta"
  submitSurveyResponse(input: SubmitSurveyResponseInput!, jwt: String!): SurveyResponseType!
  "Eliminar una encuesta (requiere rol admin)"
  deleteSurvey(surveyId: String!, jwt: String!): Boolean!
  "Agregar producto a favoritos"
  addFavorite(productId: String!, jwt: String = null): FavoriteCartType
  "Agregar producto al carrito"
  addToCart(productId: String!, jwt: String = null): FavoriteCartType
  "Remover producto de favoritos"
  removeFavorite(productId: String!, jwt: String = null): Boolean!
  "Remover producto del carrito"
  removeFromCart(productId: String!, jwt: String = null): Boolean!
  "Registrar clic en resultado de búsqueda"
  trackSearchClick(searchQuery: String!, itemId: String!, itemType: String!, jwt: String = null): SearchType!
  "Agregar like a un branch"
  likeBranch(branchId: String!, jwt: String = null): BranchLikeType!
  "Remover like de un branch"
  unlikeBranch(branchId: String!, jwt: String = null): Boolean!
  "Create a new tutorial (admin only)"
  createTutorial(input: CreateTutorialInput!, jwt: String = null): TutorialType!
  "Update a tutorial (admin only)"
  updateTutorial(id: String!, input: UpdateTutorialInput!, jwt: String = null): TutorialType!
  "Delete a tutorial (admin only)"
  deleteTutorial(id: String!, jwt: String = null): Boolean!
  "Toggle tutorial active status (admin only)"
  toggleTutorialActive(id: String!, jwt: String = null): TutorialType!
  "Crear una nueva lista de variantes"
  createVariantList(input: CreateVariantListInput!, jwt: String = null): VariantListType!
  "Actualizar una lista de variantes existente"
  updateVariantList(input: UpdateVariantListInput!, jwt: String = null): VariantListType!
  "Eliminar una lista de variantes"
  deleteVariantList(variantListId: String!, jwt: String = null): Boolean!
}
